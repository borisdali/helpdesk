# Model configuration (required)
# Supported vendors: anthropic, gemini (or google)
HELPDESK_MODEL_VENDOR=anthropic
HELPDESK_API_KEY=<your-api-key-here>

# Model names by vendor (pick ONE):
#
# Anthropic models:
#   claude-haiku-4-5-20251001   - Fast, cost-effective
#   claude-sonnet-4-20250514    - Balanced performance
#   claude-opus-4-5-20251101    - Most capable
HELPDESK_MODEL_NAME=claude-haiku-4-5-20251001
#
# Gemini models (require function calling support):
#   gemini-2.5-flash            - Fast, recommended for most use cases
#   gemini-2.5-flash-lite       - Fastest, lower cost
#   gemini-2.5-pro              - Most capable 2.5 model
#   gemini-3-flash-preview      - Latest 3.0 series, fast
#   gemini-3-pro-preview        - Latest 3.0 series, most capable
# HELPDESK_MODEL_NAME=gemini-2.5-flash
#
# Note: Gemini 1.x and 2.0 models are retired and will return errors.

# Kubeconfig path for K8s and incident agents (optional)
KUBECONFIG=~/.kube/config

# PostgreSQL credentials for the database agent (optional — choose one approach).
#
# Option A — .pgpass file (per-host credentials, recommended for multiple DBs):
#   Create the file:  echo "host:port:dbname:user:password" >> .pgpass && chmod 0600 .pgpass
#   PGPASSFILE=./.pgpass
#
# Option B — single global password (simpler for one-database setups):
#   PGPASSWORD=your-db-password
#
# Option B is obviously not secure nor recommended beyond throw-away
# development databases.

# Infrastructure inventory for the orchestrator (optional).
# Path to a JSON file describing your database servers, K8s clusters, and VMs.
# Copy the example and edit it with your real servers:
#   cp infrastructure.json.example infrastructure.json
HELPDESK_INFRA_CONFIG=./infrastructure.json

# Log level for all services (optional).
# "info"  = default — startup messages and warnings only
# "debug" = per-event audit logs, policy decisions, A2A calls, tool traces
# "warn"  = warnings and errors only
# HELPDESK_LOG_LEVEL=debug

# Streaming mode for the orchestrator REPL (optional).
# "sse"  = enabled (streaming responses)
# "none" = disabled
HELPDESK_STREAMING_MODE=sse

# Session-level purpose for the orchestrator REPL (optional).
# Declares an explicit purpose for every delegation made in this REPL session —
# equivalent to sending X-Purpose: <value> on every API request.
# Use when running the interactive orchestrator as an operator and policies have
# allowed_purposes conditions (e.g., pii-data-protection, break-glass workflows).
# Can also be set via CLI flag: helpdesk --purpose diagnostic
# Common values: diagnostic, remediation, compliance, emergency
# HELPDESK_SESSION_PURPOSE=diagnostic

# ─────────────────────────────────────────────────────────────────────────────
# AI Governance Configuration (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Operating mode (optional).
# Controls the governance enforcement level across all agents.
# Unset (default)      = personal/self-service mode — no governance requirements.
# "readonly-governed"  = audit + policy required at startup; write and destructive
#                        tools are unconditionally blocked in code. Recommended for
#                        initial enterprise deployments: observe before you act.
# "fix"                = read + write allowed; ALL governance modules (audit, policy,
#                        guardrails) are required — missing any is a fatal error.
# See docs/DEPLOYMENT_MODES.md for the full comparison.
# HELPDESK_OPERATING_MODE=readonly-governed
# HELPDESK_OPERATING_MODE=fix

# Audit logging (optional).
# Enabled automatically when the auditd binary is present. Set to "false" to
# disable audit logging even when auditd is running.
# HELPDESK_AUDIT_ENABLED=true
#
# URL of the running auditd service. Required by the approvals and govexplain
# CLIs and by agents in governed modes. Uncomment if auditd is running locally
# (the default port used by startall.sh and docker-compose).
# HELPDESK_AUDIT_URL=http://localhost:1199

# API key for operator CLI tools (govexplain, srebot) that call the gateway.
# Can be any key with a valid hash in users.yaml — e.g. reuse GATEWAY_API_KEY.
# Used via HELPDESK_CLIENT_API_KEY env var or the --api-key flag.
# HELPDESK_CLIENT_API_KEY=gateway-api-key

# Policy enforcement (optional).
# Defines rules for read/write/destructive operations and approval requirements.
#
# HELPDESK_POLICY_FILE_HOST — path to your policy file on this host.
# Used directly by all services (no container mount needed).
# Must start with "./" (relative) or "/" (absolute). Copy the example and edit:
#   cp policies.example.yaml policies.yaml
# HELPDESK_POLICY_FILE_HOST=./policies.yaml
#
# HELPDESK_POLICY_ENABLED — controls whether agents *enforce* the policy:
#   true  = agents enforce; requires and deny according to your rules.
#   false = agents ignore the policy (enforcement disabled).
#   unset = auditd loads the policy for govexplain queries, but agents do not
#           enforce it. This is the default and lets you test govexplain without
#           enabling full enforcement.
# HELPDESK_POLICY_ENABLED=true

# Approval workflow (optional).
# Set to "true" to enable human-in-the-loop approval for require_approval policies.
# Requires HELPDESK_APPROVAL_WEBHOOK (or email config) so approvers can be notified.
# Without this, require_approval rules block the operation but no approval request is sent.
# HELPDESK_APPROVAL_ENABLED=true

# Approval workflow timeout (default: 5m)
# How long agents wait for human approval before timing out.
HELPDESK_APPROVAL_TIMEOUT=5m

# API key for the `approvals` CLI (list/approve/deny pending requests).
# Can be any key with a valid hash in users.yaml — e.g. reuse GATEWAY_API_KEY.
# Used via HELPDESK_APPROVAL_KEY env var or the --api-key flag.
# HELPDESK_APPROVAL_KEY=gateway-api-key

# Post-mutation verification retry tuning (optional).
# Controls how many times mutation tools (delete_pod, cancel_query, etc.)
# re-verify that an action took effect before marking the result as
# "verified_warning" in the journey summary.
# HELPDESK_VERIFY_MAX_ATTEMPTS=3
# HELPDESK_VERIFY_INITIAL_DELAY_S=2
# HELPDESK_VERIFY_MAX_DELAY_S=30

# Identity & access control (optional).
# Controls how the gateway authenticates callers.
#
# HELPDESK_IDENTITY_PROVIDER — authentication mode for the gateway:
#   none   = accept X-User header without validation (default, dev-only)
#   static = validate against a users.yaml file (see HELPDESK_USERS_FILE_HOST)
#   jwt    = validate RS256/ES256 JWT via JWKS endpoint (see HELPDESK_JWT_JWKS_URL)
# HELPDESK_IDENTITY_PROVIDER=static
#
# HELPDESK_USERS_FILE_HOST — path to your users.yaml on this host.
# Used directly by all services (no container mount needed).
# Copy the example and edit it with your users and roles:
#   cp users.example.yaml users.yaml
# HELPDESK_USERS_FILE_HOST=./users.yaml
#
# JWT authentication settings (required when HELPDESK_IDENTITY_PROVIDER=jwt):
# HELPDESK_JWT_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
# HELPDESK_JWT_ISSUER=https://your-idp.example.com        # optional: validate iss claim
# HELPDESK_JWT_AUDIENCE=helpdesk                          # optional: validate aud claim
# HELPDESK_JWT_ROLES_CLAIM=groups                         # optional: claim to read roles from (default: roles)
# HELPDESK_JWT_CACHE_TTL=5m                               # optional: JWKS key cache TTL (default: 5m)
#
# HELPDESK_REQUIRE_PURPOSE_FOR_SENSITIVE — when "true", agents deny tool calls
# against pii or critical resources unless the caller declared an explicit purpose
# (via X-Purpose header or request body). Applies to database-agent and k8s-agent.
# HELPDESK_REQUIRE_PURPOSE_FOR_SENSITIVE=true

# Fleet jobs directory (optional).
# Directory on the host where fleet job JSON files are read and written.
# --plan-fleet-job writes planned jobs here; fleet-runner reads them from the same place.
# FLEET_JOBS_DIR=./jobs

# Fleet runner API key (required when using the fleet-runner profile).
# fleet-runner authenticates to the gateway as a service account. Generate a
# unique key and add its Argon2id hash to users.yaml under the fleet-runner entry:
#
#   openssl rand -hex 32          # generates the plaintext key — save this as FLEET_RUNNER_API_KEY
#   go run ./cmd/hashapikey       # hashes it — paste the output into users.yaml fleet-runner.api_key_hash
#
# Each service account MUST have its own unique key. Do NOT reuse srebot's or
# secbot's key: the identity provider matches on the first account whose hash
# verifies, so a shared key resolves to whichever account happens to come first
# (non-deterministic map iteration), breaking per-service audit trails and policy matching.
# FLEET_RUNNER_API_KEY=
#
# govbot and secbot API keys (required when HELPDESK_IDENTITY_PROVIDER=static).
# Each needs an entry in users.yaml with the Argon2id hash of its key.
# GOVBOT_API_KEY=
# SECBOT_API_KEY=

# Internal service account API keys (required when HELPDESK_OPERATING_MODE=fix or readonly-governed).
# Each agent and the gateway authenticate to auditd using a Bearer token.
# Generate unique keys for each service account and add their Argon2id hashes to users.yaml:
#
#   openssl rand -hex 32 | tee /dev/stderr | go run ./cmd/hashapikey
#   # → prints the plaintext key (save as the env var) and the hash (paste into users.yaml)
#
# Then set HELPDESK_IDENTITY_PROVIDER=static and HELPDESK_USERS_FILE_HOST=./users.yaml.
# GATEWAY_API_KEY=
# DB_AGENT_API_KEY=
# K8S_AGENT_API_KEY=
# SYSADMIN_AGENT_API_KEY=
# INCIDENT_AGENT_API_KEY=
# RESEARCH_AGENT_API_KEY=
# ORCHESTRATOR_API_KEY=
#
# Gateway → agent API key (required when agents enforce inbound auth via HELPDESK_USERS_FILE).
# The gateway sends this as a Bearer token to every agent /tool/{name} endpoint.
# Add a "gateway" entry to users.yaml with the Argon2id hash of this key.
# HELPDESK_AGENT_API_KEY=

# Webhook URL for approval notifications (Slack, etc.)
# HELPDESK_APPROVAL_WEBHOOK=https://hooks.slack.com/services/...

# Base URL for approve/deny links in emails
# HELPDESK_APPROVAL_BASE_URL=http://localhost:1199

# Auditor event logging (optional).
# When running with --governance, the auditor logs every event in human-readable
# form to /tmp/helpdesk-auditor.log. Set to "false" to suppress event lines and
# only log alerts (low confidence, dangerous actions, chain integrity failures, etc.).
# HELPDESK_AUDITOR_LOG_ALL=true

# Webhook URL for security alerts (auditor/secbot)
# HELPDESK_ALERT_WEBHOOK=https://hooks.slack.com/services/...

# Email configuration for notifications (optional)
# Used by auditd for approval emails and auditor for alerts.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your-password
# HELPDESK_EMAIL_FROM=helpdesk@example.com
# HELPDESK_EMAIL_TO=ops@example.com,security@example.com
